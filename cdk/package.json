{
  "name": "@eduboost/cdk",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "cdk-app": "bin/app.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "synth": "cdk synth --profile malek.atia2",
    "deploy": "cdk deploy --profile malek.atia2 --require-approval never",
    "deploy:db": "cdk deploy EduBoost-Db --profile malek.atia2 --require-approval never",
    "deploy:auth": "cdk deploy EduBoost-Auth --profile malek.atia2 --require-approval never",
    "deploy:storage": "cdk deploy EduBoost-Storage --profile malek.atia2 --require-approval never",
    "deploy:api": "cdk deploy EduBoost-Api --profile malek.atia2 --require-approval never",
    "deploy:web": "cdk deploy EduBoost-Web --profile malek.atia2 --require-approval never",
    "diff": "cdk diff --profile malek.atia2",
    "bootstrap": "cdk bootstrap --profile malek.atia2 aws://538430558070/eu-west-1"
  },
  "dependencies": {
    "aws-cdk-lib": "2.170.0",
    "cdk-nextjs-standalone": "^4.3.3",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "aws-cdk": "2.170.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
